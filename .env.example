# ============================================================================
#  Reza Ohadi — Environment Variables
#  Copy this file to `.env.local` and fill in real values.
#  The site runs in "placeholder mode" with NONE of these set — it will show
#  demo content and disable live payments. Add credentials to go live.
# ============================================================================

# ---- Site -------------------------------------------------------------------
# Public base URL of the deployment (no trailing slash). Used for SEO, OG
# images, sitemap, Stripe success/cancel URLs and email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ---------------------------------------------------------------
# Project URL + anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never expose to the client. Grants full DB
# and Storage access; used by webhooks, secure downloads and admin writes.
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket names (defaults shown). Create these in Supabase Storage.
SUPABASE_PUBLIC_BUCKET=public-assets
SUPABASE_SCORES_BUCKET=scores

# ---- Stripe -----------------------------------------------------------------
# Secret key — SERVER ONLY.
STRIPE_SECRET_KEY=
# Publishable key — safe for the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from `stripe listen` or the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=

# ---- Resend (transactional email) ------------------------------------------
RESEND_API_KEY=
# Verified sender, e.g. "Reza Ohadi <store@yourdomain.com>"
EMAIL_FROM=Reza Ohadi <onboarding@resend.dev>
# Where contact-form messages are delivered.
CONTACT_TO_EMAIL=rezaohadi.music@gmail.com

# ---- Admin access -----------------------------------------------------------
# Comma-separated allowlist of emails that may access /admin. A matching user
# must also exist in Supabase Auth (and ideally have role='admin' in profiles).
ADMIN_EMAILS=rezaohadi.music@gmail.com

# ---- Secure downloads -------------------------------------------------------
# Lifetime (seconds) of signed download URLs handed to customers.
DOWNLOAD_LINK_TTL_SECONDS=300
